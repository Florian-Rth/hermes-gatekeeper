# Non-secret local development examples. Copy to .env and change values locally if needed.
# Do not commit real credentials or production secrets.

GATEKEEPER_ADMIN_USERNAME=admin
GATEKEEPER_ADMIN_PASSWORD=dev-admin-password-local-only
# Local HTTP development only. Production deployments should keep admin cookies Secure.
GATEKEEPER_ADMIN_COOKIE_SECURE=false
GATEKEEPER_ADMIN_SESSION_IDLE_MINUTES=60

GATEKEEPER_AGENT_TOKEN=dev-agent-token-local-only

GATEKEEPER_SQLITE_DATA_PATH=./data/gatekeeper.db
# Alternative shape if the app uses ASP.NET Core connection strings:
# ConnectionStrings__Default=Data Source=/data/gatekeeper.db
