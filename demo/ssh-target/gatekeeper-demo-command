#!/bin/sh
set -eu

case "${SSH_ORIGINAL_COMMAND:-}" in
  "'uname' '-a'")
    exec uname -a
    ;;
  "'df' '-h'")
    exec df -h
    ;;
  "'pgrep' '-x' 'sshd'")
    exec pgrep -x sshd
    ;;
  "'systemctl' 'restart' 'demo-app'")
    state_dir="/tmp/gatekeeper-demo"
    counter_file="$state_dir/demo-app-restart-count"
    timestamp_file="$state_dir/demo-app-last-restart"
    mkdir -p "$state_dir"
    count=0
    if [ -f "$counter_file" ]; then
      count=$(cat "$counter_file")
    fi
    count=$((count + 1))
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    printf '%s\n' "$count" > "$counter_file"
    printf '%s\n' "$timestamp" > "$timestamp_file"
    printf 'demo-app: restart acknowledged (count=%s, at=%s)\n' "$count" "$timestamp"
    exit 0
    ;;
  *)
    echo "Command is not allowed by the Gatekeeper demo target." >&2
    exit 126
    ;;
esac
